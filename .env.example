# SST SAP Support Desk Environment Configuration
# Copy this file to .env.local for local development or set these variables in Vercel.

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-key

# Server-only secret (never expose to the browser). Used by server routes/actions.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-service-role-key

# Microsoft Teams notification integration (SERVER-ONLY — do NOT prefix with NEXT_PUBLIC_).
# Incoming webhook for a Teams channel, created via Workflows / Power Automate
# ("Post to a channel when a webhook request is received"). Leave unset to disable
# Teams delivery — the app then sends in-app notifications only. See README.
TEAMS_WEBHOOK_URL=

# Public base URL of the app, used to build the "View in Assist360" deep links in
# Teams cards (e.g. https://assist360.example.com). No trailing slash needed.
APP_BASE_URL=https://your-app-domain.example.com
